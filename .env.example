# BOSMAX agent environment — example values only. NEVER commit a real .env.

# ── Postiz integration (feature-flagged; default OFF) ─────────────────────
# With POSTIZ_ENABLED=false the adapter fails closed (503 POSTIZ_DISABLED)
# and BOSMAX behaves exactly as before.
POSTIZ_ENABLED=false
POSTIZ_BASE_URL=http://localhost:5000
POSTIZ_API_KEY=
# file = multipart upload of the local artifact (default; works fully local).
# url  = Postiz fetches a public HTTPS URL — requires POSTIZ_PUBLIC_MEDIA_BASE_URL;
#        localhost/private URLs are rejected by design.
POSTIZ_UPLOAD_MODE=file
# draft | schedule | now — draft is the safe default.
POSTIZ_DEFAULT_POST_TYPE=draft
# Only for POSTIZ_UPLOAD_MODE=url: public HTTPS base (CDN/object storage)
# under which output/retrieved/<media_id>.<ext> files are exposed.
# For TikTok this domain must ALSO be verified in the TikTok developer console.
POSTIZ_PUBLIC_MEDIA_BASE_URL=
# Public API prefix. Self-hosted docker serves it under /api/public/v1
# (default). Postiz Cloud: set POSTIZ_BASE_URL=https://api.postiz.com and
# POSTIZ_API_PREFIX=/public/v1.
POSTIZ_API_PREFIX=/api/public/v1

# Native Google Flow Extend + server concat lane (video-extension module).
# 1 enables /extend-run + finalize concat + durable scene bootstrap. Default off.
NATIVE_EXTEND_ENABLED=1
