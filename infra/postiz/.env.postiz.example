# Postiz service secrets — copy to infra/postiz/.env and fill. NEVER commit .env.
JWT_SECRET=CHANGE_ME_LONG_RANDOM_STRING
POSTGRES_PASSWORD=CHANGE_ME_DB_PASSWORD

# Public URLs (must be HTTPS + a real domain for TikTok/Meta OAuth callbacks):
MAIN_URL=http://localhost:5000
FRONTEND_URL=http://localhost:5000
NEXT_PUBLIC_BACKEND_URL=http://localhost:5000/api

# Provider OAuth apps — fill only the providers you connect:
# TikTok developer app (Content Posting API + Direct Post; HTTPS redirect URI;
# verified media domain; scopes: user.info.basic, user.info.profile,
# video.create, video.publish, video.upload):
#TIKTOK_CLIENT_ID=
#TIKTOK_CLIENT_SECRET=
# Meta app (must be LIVE for public visibility; business permissions):
#FACEBOOK_APP_ID=
#FACEBOOK_APP_SECRET=
#YOUTUBE_CLIENT_ID=
#YOUTUBE_CLIENT_SECRET=
#X_API_KEY=
#X_API_SECRET=
